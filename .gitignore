# ============================================================
# 📘 .gitignore 说明
# ============================================================
# 哪些文件不应该提交到 git？
# - node_modules/：依赖包，太大且可通过 npm install 恢复
# - .env*：环境变量，包含密钥等敏感信息
# - dist/build/：构建产物，可通过 npm run build 重新生成
# - .claude/settings.local.json：个人配置，不应影响团队
# ============================================================

# 依赖
node_modules/

# 构建产物
dist/
build/
.next/
.nuxt/
.output/
out/

# 环境变量（敏感信息）
.env
.env.local
.env.*.local

# Claude 个人配置（不提交到团队仓库）
.claude/settings.local.json

# 系统文件
.DS_Store
Thumbs.db

# 编辑器
.vscode/settings.json
.idea/

# 日志和缓存
*.log
npm-debug.log*
.cache/
coverage/
.turbo/

# 临时文件
*.tmp
*.swp
.gstack/
